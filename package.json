{
  "name": "frost",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:app": "npm -w @frost/app run dev",
    "dev:website": "npm -w @frost/website run dev",
    "dev:portal": "npm -w @frost/portal run dev",
    "dev:mobile": "npm -w @frost/mobile-website run start",
    "lint": "turbo lint",
    "type-check": "turbo type-check"
  },
  "devDependencies": {
    "playwright": "^1.58.2",
    "turbo": "^2.8.14"
  }
}
