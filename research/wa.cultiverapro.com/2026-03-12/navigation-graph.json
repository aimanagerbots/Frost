  "drillDownTrails": [
    {
      "trail": "Sales → Carts → row click → Cart Detail",
      "from": "sales-carts",
      "to": "cart-detail",
      "trigger": "click date/link in row",
      "screenshot": "sales/states/cart-detail-prc-conway.png",
      "note": "Cart detail shows 16 line items, $621.60 total for PRC Conway"
    },
    {
      "trail": "Fulfillment → Transfer Inbound → TSID row click → Transfer Detail",
      "from": "ful-transfer-inbound",
      "to": "transfer-inbound-detail",
      "trigger": "click TSID link in row",
      "screenshot": "fulfillment/states/transfer-inbound-detail.png",
      "note": "Non-Cannabis transfer from Richards Packaging Inc, In Transit"
    },
    {
      "trail": "Grow → Disposal → Destroyed tab",
      "from": "grow-disposal",
      "to": "disposal-destroyed-tab",
      "trigger": "click Destroyed tab",
      "screenshot": "grow/states/disposal-destroyed-tab.png",
      "note": "261 destroyed records with Source TSID, Disposal TSID, Strain, Qty, etc."
    },
    {
      "trail": "Analytics → Overview → report card click → Report Detail",
      "from": "analytics-overview",
      "to": "analytics-report-detail",
      "trigger": "click report card",
      "screenshot": "analytics/states/client-by-product-report.png",
      "note": "Tabbed report with filter status tabs"
    }
  ],
  "navigationNotes": [
    "NEVER navigate by constructing URLs — always use module switcher clicks for cross-module nav",
    "ALWAYS click sidebar items for within-module navigation",
    "SPA with hash routing — direct URL navigation causes 404 for non-root routes",
    "Exception: /configuration sub-app appears to support direct URL navigation to hash routes"
  ]
}
